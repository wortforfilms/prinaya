{
  "name": "tlp-wedding-cad-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "node scripts/apply-sqlite-migration.mjs",
    "db:seed": "node --import tsx prisma/seed.ts",
    "hero:extract": "python3 scripts/extract-hero-banners.py",
    "hero:generate": "python3 scripts/extract-hero-banners.py",
    "tlps:extract": "python3 scripts/extract-tlps-homepage.py",
    "tlps:extract:unique": "python3 scripts/extract-unique-tlps-assets.py",
    "images:cinematic": "python3 scripts/generate-cinematic-assets.py",
    "assets:generate": "tsx scripts/generate-assets.ts",
    "mesh:generate": "tsx scripts/generate-assets.ts",
    "pdf:generate": "node --import tsx scripts/generate-board-pdf.ts",
    "cad:fixtures": "node --import tsx scripts/generate-cad-fixtures.ts",
    "evidence:generate": "node --import tsx scripts/generate-evidence.ts",
    "verify:assets": "tsx scripts/verify-assets.ts",
    "verify:hero": "node --import tsx scripts/verify-hero-banners.ts",
    "verify:tlps": "node --import tsx scripts/verify-tlps-homepage.ts",
    "verify:tlps:unique": "node --import tsx scripts/verify-tlps-unique-extractions.ts",
    "verify:cinematic": "node --import tsx scripts/verify-cinematic-assets.ts",
    "verify:pdf": "node --import tsx scripts/verify-pdf-board.ts",
    "verify:cad:fixtures": "node --import tsx scripts/verify-cad-fixtures.ts",
    "verify:routes": "node --import tsx scripts/verify-routes.ts",
    "verify:active-pages": "tsx scripts/verify-active-pages.ts",
    "verify:usecases": "tsx scripts/verify-usecases.ts",
    "verify:schema": "node --import tsx scripts/verify-schema.ts",
    "verify:cad": "node --import tsx scripts/verify-cad.ts",
    "verify:cad:visual": "node scripts/verify-cad-visual.mjs",
    "verify:evidence": "node --import tsx scripts/verify-evidence.ts",
    "verify:release": "node --import tsx scripts/verify-release.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.10.0",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "prisma": "^6.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.171.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
